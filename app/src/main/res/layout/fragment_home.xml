<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <include layout="@layout/layout_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="30dp"
                android:paddingTop="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:background="@drawable/bg_balance_card"
                    android:elevation="8dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingHorizontal="48dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tổng số dư"
                        android:textColor="@color/mint_green"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/txtBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="12,450,000 đ"
                        android:textColor="@android:color/white"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="↗  +2.4% so với tháng trước"
                        android:textColor="@color/mint_green"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="48dp"
                    android:background="@drawable/bg_card_figma"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:maxLines="2"
                            android:text="Chi tiêu tuần này"
                            android:textColor="@color/text_main"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtWeekTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="3,200,000 đ"
                            android:textColor="@color/primary_green"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="88dp"
                        android:layout_marginTop="20dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:background="@color/green_light" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:background="@color/green_light" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:gravity="bottom|center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T4"
                                android:textColor="@color/primary_green"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:background="@color/primary_green" />
                        </LinearLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:background="@color/green_light" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:background="@color/border_light" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="18dp"
                            android:layout_weight="1"
                            android:background="@color/border_light" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Giao dịch gần đây"
                        android:textColor="@color/text_main"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="Xem tất cả"
                        android:textColor="@color/primary_green"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtEmptyExpense"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_card_figma"
                    android:gravity="center"
                    android:text="Chưa có chi tiêu nào"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutExpenseList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>