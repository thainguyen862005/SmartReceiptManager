<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@color/bg_surface"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="22dp"
    android:paddingEnd="22dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardHeaderAvatar"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardBackgroundColor="@color/border_light"
        app:cardCornerRadius="17dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgHeaderAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/sym_def_app_icon" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Smart Receipt Manager"
        android:textColor="@color/primary_green"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ImageView
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:contentDescription="Thông báo"
        android:padding="6dp"
        android:src="@drawable/ic_bell" />
</LinearLayout>
