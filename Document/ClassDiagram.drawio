<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="e8Jvx-EncH7AJmM74GpY">
    <mxGraphModel dx="2916" dy="1189" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Class Diagram - Smart Receipt Manager\n\nclass LoginActivity {\n  +onCreate()\n  +login()\n  +goToRegister()\n}\n\nclass RegisterActivity {\n  +onCreate()\n  +register()\n}\n\nclass AddExpenseActivity {\n  +onCreate()\n  +saveExpense()\n  +suggestCategory()\n  +fillDataFromOCR()\n}\n\nclass ScanReceiptActivity {\n  +selectImage()\n  +scanReceipt()\n  +showOCRResult()\n}\n\nclass StatisticsActivity {\n  +showMonthlyTotal()\n  +showCategoryReport()\n}\n\nclass AuthViewModel {\n  -AuthRepository authRepository\n  +login(email, password)\n  +register(email, password)\n  +logout()\n}\n\nclass ExpenseViewModel {\n  -ExpenseRepository expenseRepository\n  +addExpense(expense)\n  +updateExpense(expense)\n  +deleteExpense(expense)\n  +getExpenses()\n  +suggestCategory(data)\n}\n\nclass ScanViewModel {\n  -ScanRepository scanRepository\n  +processImage(imageUri)\n}\n\nclass StatisticsViewModel {\n  -StatisticsRepository statisticsRepository\n  +getMonthlyTotal()\n  +getCategoryStatistics()\n}\n\nclass AuthRepository {\n  -FirebaseService firebaseService\n  +login(email, password)\n  +register(email, password)\n}\n\nclass ExpenseRepository {\n  -ExpenseDao expenseDao\n  -FirebaseService firebaseService\n  -ApiService apiService\n  +insertExpense(expense)\n  +updateExpense(expense)\n  +deleteExpense(expense)\n  +syncExpense(expense)\n  +suggestCategory(data)\n}\n\nclass ScanRepository {\n  -OcrProcessor ocrProcessor\n  -ReceiptParser receiptParser\n  +recognizeReceipt(imageUri)\n}\n\nclass StatisticsRepository {\n  -ExpenseDao expenseDao\n  +getMonthlyTotal()\n  +getTotalByCategory()\n}\n\nclass FirebaseService {\n  +login()\n  +register()\n  +syncExpense()\n  +getCurrentUserId()\n}\n\nclass ApiService {\n  +categorizeExpense(request)\n}\n\nclass OcrProcessor {\n  +recognizeText(imageUri)\n}\n\nclass ReceiptParser {\n  +extractAmount(rawText)\n  +extractDate(rawText)\n  +extractMerchantName(rawText)\n}\n\nclass ExpenseDao {\n  +insert(expense)\n  +update(expense)\n  +delete(expense)\n  +getAllExpenses()\n  +getUnsyncedExpenses()\n}\n\nclass AppDatabase {\n  +getInstance()\n  +expenseDao()\n}\n\nclass Expense {\n  +String id\n  +String userId\n  +String merchantName\n  +double amount\n  +String category\n  +long date\n  +String note\n  +String receiptText\n  +boolean isSynced\n  +long createdAt\n  +long updatedAt\n}\n\nclass Category {\n  +String id\n  +String name\n  +String icon\n}\n\nLoginActivity --&gt; AuthViewModel\nRegisterActivity --&gt; AuthViewModel\nAddExpenseActivity --&gt; ExpenseViewModel\nScanReceiptActivity --&gt; ScanViewModel\nStatisticsActivity --&gt; StatisticsViewModel\n\nAuthViewModel --&gt; AuthRepository\nExpenseViewModel --&gt; ExpenseRepository\nScanViewModel --&gt; ScanRepository\nStatisticsViewModel --&gt; StatisticsRepository\n\nAuthRepository --&gt; FirebaseService\nExpenseRepository --&gt; ExpenseDao\nExpenseRepository --&gt; FirebaseService\nExpenseRepository --&gt; ApiService\nScanRepository --&gt; OcrProcessor\nScanRepository --&gt; ReceiptParser\nStatisticsRepository --&gt; ExpenseDao\n\nAppDatabase --&gt; ExpenseDao\nExpenseDao --&gt; Expense\nExpense --&gt; Category\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="KQPjiy9l4FAFAoAhpHgG-5">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1192" width="1415" x="-160" y="30" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
